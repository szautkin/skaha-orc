# ─── Server ────────────────────────────────────────────
PORT=3001

# ─── Helm / Charts ────────────────────────────────────
HELM_CONFIG_DIR=./helm-values          # Directory containing Helm values files
CHART_BASE_DIR=./charts                # Base directory for local chart paths
HELM_BINARY=helm
KUBECTL_BINARY=kubectl

# ─── Platform ─────────────────────────────────────────
PLATFORM_HOSTNAME=haproxy.cadc.dao.nrc.ca   # Platform-wide hostname used in extraHosts

# ─── HAProxy ──────────────────────────────────────────
HAPROXY_CONFIG_PATH=./haproxy/haproxy.cfg
HAPROXY_BINARY=haproxy

# ─── Kubernetes Context (optional) ────────────────────
# KUBE_CONTEXT=minikube                # Kubectl --context value
# KUBECONFIG=~/.kube/config            # Path to kubeconfig file

# ─── CORS (optional) ─────────────────────────────────
# CORS_ORIGINS=http://localhost:5173   # Comma-separated allowed origins (default: allow all)
